{
  "name": "prompt-vault",
  "version": "1.0.0",
  "description": "AI Prompt Management System",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:server\"",
    "dev:web": "next dev",
    "dev:server": "nest start --watch",
    "build": "npm run build:web && npm run build:server",
    "build:web": "next build",
    "build:server": "nest build",
    "start": "npm run start:web & npm run start:server",
    "start:web": "next start",
    "start:server": "node dist/server/main",
    "lint": "next lint && nest lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@prisma/client": "^5.7.0",
    "nestjs": "^0.0.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "bcrypt": "^5.1.1",
    "zod": "^3.22.0",
    "zustand": "^4.4.0",
    "meilisearch": "^0.36.0",
    "ioredis": "^5.3.0",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/bcrypt": "^5.0.2",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-local": "^1.0.38",
    "prisma": "^5.7.0",
    "eslint": "^8.55.0",
    "eslint-config-next": "^14.0.0",
    "concurrently": "^8.2.0"
  }
}
